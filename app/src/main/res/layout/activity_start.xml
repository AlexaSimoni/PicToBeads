<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_blue"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create something new today"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@+id/btn_bracelet"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <ImageButton
        android:id="@+id/btn_bracelet"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="32dp"
        app:srcCompat="@drawable/outline_brush_24"
        android:background="@android:color/transparent"
        app:tint="@android:color/white"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toTopOf="@+id/tv_label_bracelet"
        app:layout_constraintEnd_toStartOf="@+id/btn_picture"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title" />

    <TextView
        android:id="@+id/tv_label_bracelet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Bracelet"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@+id/btn_bracelet"
        app:layout_constraintStart_toStartOf="@+id/btn_bracelet"
        app:layout_constraintTop_toBottomOf="@+id/btn_bracelet" />

    <ImageButton
        android:id="@+id/btn_picture"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:srcCompat="@drawable/outline_image_24"
        android:background="@android:color/transparent"
        app:tint="@android:color/white"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="@+id/btn_bracelet"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btn_bracelet"
        app:layout_constraintTop_toTopOf="@+id/btn_bracelet" />

    <TextView
        android:id="@+id/tv_label_picture"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Picture"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_label_bracelet"
        app:layout_constraintEnd_toEndOf="@+id/btn_picture"
        app:layout_constraintStart_toStartOf="@+id/btn_picture"
        app:layout_constraintTop_toTopOf="@+id/tv_label_bracelet" />

</androidx.constraintlayout.widget.ConstraintLayout>